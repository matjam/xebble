@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

find_dependency(Vulkan)
find_dependency(glfw3 CONFIG)
find_dependency(VulkanMemoryAllocator CONFIG)
find_dependency(freetype CONFIG)
find_dependency(glm CONFIG)
find_dependency(tomlplusplus CONFIG)
find_dependency(miniz CONFIG)
find_dependency(libxmp CONFIG)

# miniaudio is header-only; locate it the same way the library build does.
find_path(MINIAUDIO_INCLUDE_DIR miniaudio.h REQUIRED)
if(NOT TARGET miniaudio::miniaudio)
    add_library(miniaudio::miniaudio INTERFACE IMPORTED)
    target_include_directories(miniaudio::miniaudio INTERFACE "${MINIAUDIO_INCLUDE_DIR}")
endif()

include("${CMAKE_CURRENT_LIST_DIR}/xebbleTargets.cmake")

# Expose the installed shader directory so consumers can pass it to the renderer.
set_and_check(XEBBLE_SHADER_DIR "@PACKAGE_XEBBLE_SHADER_INSTALL_DIR@")

check_required_components(xebble)
